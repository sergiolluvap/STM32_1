    if (htim->Instance == TIM2) {
        // Pulso de SYNC a todos los sensores
        GPIOC->BSRR = GPIO_PIN_0; 
        __asm("nop"); // Pulso corto
        GPIOC->BSRR = (GPIO_PIN_0 << 16);
    }
